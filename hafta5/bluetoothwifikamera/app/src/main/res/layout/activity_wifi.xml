<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:orientation="vertical"

    android:background="#121212"

    android:padding="32dp"

    android:gravity="center">



    <TextView

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:text="Wİ-Fİ KONTROL"

        android:textColor="#FFFFFF"

        android:textSize="24sp"

        android:textStyle="bold"

        android:layout_marginBottom="48dp" />



    <Button

        android:id="@+id/btnWifiAyar"

        android:layout_width="match_parent"

        android:layout_height="80dp"

        android:background="@drawable/glass_button_bg"

        android:text="Wİ-Fİ PANELİNİ AÇ"

        android:textColor="#FF20A2"

        android:textSize="20sp"

        android:letterSpacing="0.1" />



    <TextView

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:layout_marginTop="24dp"

        android:text="Modern cihazlarda Wi-Fi kontrolü sistem paneli üzerinden yapılmaktadır."

        android:textColor="#80FFFFFF"

        android:textAlignment="center"

        android:textSize="14sp" />



</LinearLayout>