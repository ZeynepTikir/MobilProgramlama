<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F9"
    android:padding="16dp">

    <!-- Veri Giriş Alanı (Kart Tasarımı) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soru Yönetim Paneli"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/editSoru" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Soru Metni" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <EditText android:id="@+id/editA" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="A Şıkkı" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginEnd="4dp"/>
                <EditText android:id="@+id/editB" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="B Şıkkı" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <EditText android:id="@+id/editC" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="C Şıkkı" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginEnd="4dp"/>
                <EditText android:id="@+id/editD" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="D Şıkkı" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <EditText android:id="@+id/editE" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="E Şıkkı" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginEnd="4dp"/>
                <EditText android:id="@+id/editDogru" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Doğru (Örn: A)" android:background="@android:drawable/editbox_background" android:padding="12dp" android:layout_marginStart="4dp" android:textColor="#4CAF50" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Kontrol Butonları -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <Button android:id="@+id/btnEkle" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Ekle" android:layout_weight="1" android:backgroundTint="#4CAF50" android:textColor="#FFF" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnGuncelle" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Güncelle" android:layout_weight="1" android:backgroundTint="#2196F3" android:textColor="#FFF" android:layout_marginEnd="4dp" android:layout_marginStart="4dp"/>
        <Button android:id="@+id/btnSil" android:layout_width="0dp" android:layout_height="wrap_content" android:text="Sil" android:layout_weight="1" android:backgroundTint="#F44336" android:textColor="#FFF" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Sorular Listesi -->
    <ListView
        android:id="@+id/listViewSorular"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

    <!-- Sınava Başla Butonu -->
    <Button
        android:id="@+id/btnSinavaBasla"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SINAVA BAŞLA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"/>

</LinearLayout>